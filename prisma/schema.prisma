generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
  MASTER_ADMIN
  ORG_ADMIN
  HR
  MANAGER
  VIEWER
}

enum AttendanceType {
  CLOCK_IN
  CLOCK_OUT
  BREAK_START
  BREAK_END
}

enum SessionStatus {
  CLOCKED_IN
  CLOCKED_OUT
  ON_BREAK
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PurchaseIntentStatus {
  PENDING
  CHECKOUT_CREATED
  PAID
  FAILED
  CANCELED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum PaymentProvider {
  STRIPE
  FLUTTERWAVE
}

model Organization {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  slug        String       @unique
  email       String?
  phone       String?
  users        User[]
  employees    Employee[]
  attendances  Attendance[]
  devices      Device[]
  sessions     AttendanceSession[]
  violations   AttendanceViolation[]
  shifts       Shift[]
  shiftAssignments EmployeeShiftAssignment[]
  shiftOverrides   ShiftOverride[]
  faceEmbeddings   EmployeeFaceEmbedding[]
  payPeriods       PayPeriod[]
  paySummaries     EmployeePaySummary[]
  subscription     OrganizationSubscription?
  trialSignups     TrialSignup[]
  purchaseIntents  PurchaseIntent[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([email])
}

model SubscriptionPlan {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique
  name            String
  description     String   @default("")
  monthlyPrice    Int      @default(0)
  yearlyPrice     Int      @default(0)
  currency        String   @default("USD")
  maxEmployees    Int      @default(10)
  maxDevices      Int      @default(1)
  features        Json?
  isActive        Boolean  @default(true)
  subscriptions   OrganizationSubscription[]
  purchaseIntents PurchaseIntent[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, code])
}

model OrganizationSubscription {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationId       String             @unique @db.Uuid
  subscriptionPlanId   String             @map("planId") @db.Uuid
  status               SubscriptionStatus @default(INCOMPLETE)
  billingCycle         BillingCycle       @default(MONTHLY)
  provider             PaymentProvider?
  providerCustomerId   String?
  providerSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd DateTime?
  
  organization    Organization     @relation(fields: [organizationId], references: [id])
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, currentPeriodEnd])
  @@index([provider, providerSubscriptionId])
}

model PayPeriod {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  startDate      DateTime @db.Date
  endDate        DateTime @db.Date
  status         String   @default("open") // "open", "closed", "paid"
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  summaries      EmployeePaySummary[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, startDate, endDate])
}

model EmployeePaySummary {
  id             String   @id @default(uuid()) @db.Uuid
  employeeId     String   @db.Uuid
  organizationId String   @db.Uuid
  payPeriodId    String   @db.Uuid
  
  totalHours     Float    @default(0)
  overtimeHours  Float    @default(0)
  basePay        Int      @default(0) // in cents
  overtimePay    Int      @default(0)
  bonusPay       Int      @default(0)
  deductions     Int      @default(0)
  meta           Json?
  
  employee       Employee     @relation(fields: [employeeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  payPeriod      PayPeriod    @relation(fields: [payPeriodId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([employeeId, payPeriodId])
}

model Device {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  token          String       @unique
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  lastActiveAt   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([token])
}

model User {
  id             String        @id @db.Uuid
  email          String        @unique
  name           String?
  phone          String?
  department     String?
  title          String?
  bio            String?
  role           Role          @default(USER)
  faceEmbedding  Json?
  faceEnrolledAt DateTime?
  organizationId String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id])
  trialSignups   TrialSignup[]
  passwordResetTokens PasswordResetToken[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model EmailLog {
  id        String   @id @default(uuid()) @db.Uuid
  recipient String
  subject   String
  type      String
  status    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([recipient, createdAt])
  @@index([status, createdAt])
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  email      String
  userId     String?   @db.Uuid
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([expiresAt])
  @@index([usedAt])
}

model DemoRequest {
  id          String   @id @default(uuid()) @db.Uuid
  fullName    String
  company     String
  email       String
  phone       String
  teamSize    String
  message     String
  status      String   @default("new")
  submittedIp String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model ContactMessage {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  email       String
  company     String
  subject     String
  message     String
  status      String   @default("new")
  submittedIp String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model TrialSignup {
  id               String        @id @default(uuid()) @db.Uuid
  businessEmail    String
  organizationName String
  teamSize         String
  status           String        @default("provisioned")
  planCode         String
  submittedIp      String?
  userAgent        String?
  organizationId   String?       @db.Uuid
  userId           String?       @db.Uuid
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user             User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([businessEmail])
  @@index([status, createdAt])
  @@index([organizationId])
  @@index([userId])
}

model PurchaseIntent {
  id               String               @id @default(uuid()) @db.Uuid
  organizationId   String               @db.Uuid
  subscriptionPlanId String             @db.Uuid
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan     @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  billingCycle     BillingCycle
  fullName      String
  businessName  String
  workEmail     String
  phone         String
  companySize   String
  employeeCount  Int
  deviceCount    Int
  status         PurchaseIntentStatus   @default(PENDING)
  paymentProvider PaymentProvider?
  providerReference String?
  submittedIp   String?
  userAgent     String?
  paymentEvents  PaymentEvent[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([organizationId, createdAt])
  @@index([subscriptionPlanId, createdAt])
  @@index([status, createdAt])
  @@index([workEmail])
  @@index([paymentProvider, providerReference])
}

model PaymentEvent {
  id               String          @id @default(uuid()) @db.Uuid
  purchaseIntentId String          @db.Uuid
  purchaseIntent   PurchaseIntent  @relation(fields: [purchaseIntentId], references: [id], onDelete: Cascade)
  provider         PaymentProvider
  eventType        String
  providerEventId  String
  payload          Json
  createdAt        DateTime        @default(now())

  @@unique([provider, providerEventId])
  @@index([purchaseIntentId, createdAt])
}

model Employee {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  email          String?      @unique
  phone          String?
  department     String?
  title          String?
  bio            String?
  imageUrl       String?
  faceEmbedding  Json?
  faceEnrolledAt DateTime?
  organizationId String       @db.Uuid
  organization   Organization        @relation(fields: [organizationId], references: [id])
  attendances    Attendance[]
  sessions       AttendanceSession[]
  violations     AttendanceViolation[]
  shiftAssignments EmployeeShiftAssignment[]
  shiftOverrides   ShiftOverride[]
  faceEmbeddings   EmployeeFaceEmbedding[]
  paySummaries     EmployeePaySummary[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model EmployeeFaceEmbedding {
  id             String   @id @default(uuid()) @db.Uuid
  employeeId     String   @db.Uuid
  organizationId String   @db.Uuid
  embedding      Unsupported("vector(128)")
  createdAt      DateTime @default(now())

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
}

model Attendance {
  id             String         @id @default(uuid()) @db.Uuid
  employeeId     String         @db.Uuid
  organizationId String         @db.Uuid
  sessionId      String?        @db.Uuid
  type           AttendanceType
  timestamp      DateTime       @default(now())
  distance       Float
  userAgent      String?
  idempotencyKey String?        @unique
  createdAt      DateTime       @default(now())

  employee     Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id])
  session      AttendanceSession? @relation(fields: [sessionId], references: [id])

  @@index([employeeId])
  @@index([timestamp])
  @@index([organizationId])
  @@index([sessionId])
  @@index([idempotencyKey])
}

model Shift {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  startTime      String       // e.g. "09:00"
  endTime        String       // e.g. "17:00"
  graceMinutes   Int          @default(15)
  maxBreakMinutes Int         @default(60)
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  assignments    EmployeeShiftAssignment[]
  overrides      ShiftOverride[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model EmployeeShiftAssignment {
  id             String       @id @default(uuid()) @db.Uuid
  employeeId     String       @db.Uuid
  shiftId        String       @db.Uuid
  startDate      DateTime     @db.Date
  endDate        DateTime?    @db.Date
  organizationId String       @db.Uuid
  
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift          Shift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model ShiftOverride {
  id             String       @id @default(uuid()) @db.Uuid
  employeeId     String       @db.Uuid
  shiftId        String?      @db.Uuid
  date           DateTime     @db.Date
  organizationId String       @db.Uuid
  
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift          Shift?       @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model AttendanceSession {
  id             String        @id @default(uuid()) @db.Uuid
  employeeId     String        @db.Uuid
  organizationId String        @db.Uuid
  workDate       DateTime      @db.Date
  status         SessionStatus
  clockInAt      DateTime
  clockOutAt     DateTime?
  breakMinutes   Int           @default(0)
  
  // Computed Shift Metrics
  lateMinutes      Int?
  overtimeMinutes  Int?
  earlyLeaveMinutes Int?
  
  lastEventAt    DateTime      @default(now())
  events         Attendance[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([employeeId, workDate])
  @@index([employeeId])
  @@index([organizationId])
  @@index([workDate])
}

model AttendanceViolation {
  id             String   @id @default(uuid()) @db.Uuid
  employeeId     String   @db.Uuid
  organizationId String   @db.Uuid
  type           String // e.g. "DOUBLE_CLOCK_IN", "UNAUTHORIZED_DEVICE"
  message        String
  timestamp      DateTime @default(now())
  meta           Json?
  createdAt      DateTime @default(now())

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
  @@index([timestamp])
}

model SystemAdminWhitelist {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model PlatformSecret {
  key         String   @id
  value       String   // Should be encrypted in production
  description String?
  updatedAt   DateTime @updatedAt
}
